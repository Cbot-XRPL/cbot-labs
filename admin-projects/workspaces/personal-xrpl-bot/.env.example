# Example env for Personal XRPL Trading Bot workspace
# Do NOT commit secrets. Inject these at runtime via your secret manager or environment.

# Comma-separated owner xrpl addresses that are allowed to call the owner-only APIs
OWNER_WALLETS=rVeHp61gJ9MxoqMkAMmEbow8KYWk3AH1X

# XRPL node URL (optional for read-only probes). Example: wss://s1.ripple.com
RIPPLED_URL=

# XRPL wallet seed (optional). DO NOT commit into repo; if provided at runtime, server adapter may enable signing features.
XRPL_WALLET_SEED=

# Optional: server port override for the workspace
PORT=3001

# Default trade size for simulated strategies
TRADE_SIZE=1
