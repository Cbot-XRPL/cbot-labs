# Owner wallet addresses allowed to access the workspace API (comma-separated public addresses)
OWNER_WALLETS=rVeHp61gJ9MxoqMkAMmEbow8KYWk3AH1X

# Optional XRPL node URL (wss or https). If not set, adapter will operate in simulated/read-only mode.
RIPPLED_URL=wss://s.altnet.rippletest.net:51233

# Optional XRPL wallet seed for signing (DO NOT PUT REAL SECRETS IN REPO)
XRPL_WALLET_SEED=

# App port
PORT=4060

# Default trade size used in simulated trades
TRADE_SIZE=10
